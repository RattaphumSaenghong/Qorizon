# Copy to api/.env and fill in. .env is gitignored.

# Supabase Postgres (project dqrfozcaetlkgojirqjw).
# DATABASE_URL = transaction pooler (port 6543) for app queries — note ?pgbouncer=true
# DIRECT_URL   = direct connection (port 5432) for prisma migrate
DATABASE_URL="postgresql://postgres.dqrfozcaetlkgojirqjw:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.dqrfozcaetlkgojirqjw:YOUR-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Auth — generate strong random values, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

PORT="3000"

# Media storage. Leave R2_* blank for local-disk dev (files served from /uploads).
# Set all R2_* to use Cloudflare R2 (or any S3-compatible bucket) in production.
MEDIA_PUBLIC_BASE="http://localhost:3000"
MEDIA_LOCAL_DIR="uploads"
# R2_ACCOUNT_ID=""
# R2_BUCKET=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_PUBLIC_BASE="https://media.yourdomain.com"

# Bookings. Leave blank for the mock provider (dev). Set AMADEUS_* to use the
# real Amadeus flight API (free test tier at developers.amadeus.com).
# AMADEUS_CLIENT_ID=""
# AMADEUS_CLIENT_SECRET=""
# AMADEUS_THB_RATE="38"
